# Database (SQLite for local, PostgreSQL for production/Supabase)
# Local: DATABASE_URL=sqlite:///./data/edfs.db
# Supabase: DATABASE_URL=postgresql://postgres.gmclfuhsxcfoabrnagqv:YOUR-PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=sqlite:///./data/edfs.db

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# MLflow
MLFLOW_TRACKING_URI=sqlite:///./mlflow/mlflow.db
MLFLOW_ARTIFACT_ROOT=./mlflow/artifacts

# Scheduling intervals
SCRAPE_INTERVAL_HOURS=6
RETRAIN_INTERVAL_DAYS=7

# Optional: Visual Crossing API key (Open-Meteo is free and default)
# VISUAL_CROSSING_API_KEY=your-key-here
